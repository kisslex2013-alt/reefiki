# Normalize repository text files so frontmatter parsing and shell scripts behave
# consistently across Windows, macOS, Linux, and CI checkouts.
* text=auto eol=lf

*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.py text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.txt text eol=lf
*.ps1 text eol=crlf

*.db binary
*.sqlite binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.docx binary
*.pptx binary
*.xlsx binary
